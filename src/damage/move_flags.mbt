    "だんがいのつるぎ", "どくガス", "なきごえ", "なみのり",
    "にらみつける", "ねっさのあらし", "ねっぷう", "はっぱカッター",
    "はなふぶき", "はるのあらし", "ばくおんぱ", "ふしょくガス",
    "ふぶき", "ふんえん", "ふんか", "ぶんまわす",
    "ほうでん", "むしのていこう", "むにきすひかり", "もえあがるいかり",
    "やきつくす", "ゆうわく", "ようかいえき", "わたほうし",
    "アストラルビット", "エアカッター", "エレキネット", "オーバードライブ",
    "キラースピン", "グランドフォース", "コアパニッシャー", "ゴールドラッシュ",
    "サウザンアロー", "サウザンウェーブ", "シャカシャカほう", "シンクロノイズ",
    "スケイルノイズ", "スピードスター", "ダイヤストーム", "ダークホール",
    "チャームボイス", "トラップシェル", "ドラゴンエナジー", "ハイパーボイス",
    "バークアウト", "パラボラチャージ", "ビックリヘッド", "フラフラダンス",
    "ブリザードランス", "ヘドロウェーブ", "ベノムトラップ", "マグニチュード",
    "マジカルシャイン", "ミストバースト", "ワイドブレイカー",
  ].iter(),
