}

///|
let recoil_moves : @hashset.HashSet[String] = @hashset.HashSet::from_iter(
  [
    "すてみタックル", "とっしん", "ブレイブバード", "フレアドライブ", "ウッドハンマー", "ボルテッカー",
    "もろはのずつき", "じごくぐるま", "ワイルドボルト", "アフロブレイク", "もろはのやいば", "ウェーブタックル",
    "はめつのひかり",
  ].iter(),
)

///|
pub fn is_recoil_move(name : String) -> Bool {
  recoil_moves.contains(name)
}

///|
let slash_moves : @hashset.HashSet[String] = @hashset.HashSet::from_iter(
  [
    "いあいぎり", "はっぱカッター", "きりさく", "れんぞくぎり", "エアカッター", "つばめがえし", "ドラゴンクロー",
    "リーフブレード", "つじぎり", "エアスラッシュ", "シザークロス", "シャドークロー", "サイコカッター",
    "クロスポイズン", "せいなるつるぎ", "シェルブレード", "しんぴのつるぎ", "ソーラーブレード", "きょじゅうざん",
