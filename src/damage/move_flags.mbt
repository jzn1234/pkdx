///|
pub fn is_contact_move(name : String) -> Bool {
  contact_moves.contains(name)
}

///|
/// Resolve the move's effective contact flag, honoring `force_contact` from
/// `StatResolution` (シェルアームズ 物理モード等の動的接触判定) over the
/// static `is_contact_move` table. Shared by the damage engine and the
/// payoff layer's contact-proc fanout so they can never disagree.
pub fn resolve_move_contact(
  mv : @model.Move,
  force_contact : Bool?,
) -> Bool {
  match force_contact {
    Some(v) => v
    None => is_contact_move(mv.name)
  }
}

///|
/// ダブルバトルで複数対象に当たる技（0.75 倍補正対象）。
/// champout `masterdata/waza.json` の `target IN (4, 5)`
/// (4 = 自分以外全体、5 = 相手全体) を持つ全技から自動生成。
/// contact_moves と同じく available 列でフィルタしない (range は世代を
/// 跨いで universal な属性なので、SV / legendsza でも同じ table を使える)。
let spread_moves : @hashset.HashSet[String] = @hashset.HashSet::from_iter(
  [
    "あまいかおり", "あわ", "いとをはく", "いにしえのうた",
